<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#0b0b14">
    <title>{{ page_title }} &mdash; {{ shop.name }}</title>
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="icon" type="image/png" href="{{ 'favicon.png' | asset_url }}">

    {%- liquid
      # Social sharing image: the branded logo card, or the product image on product pages.
      assign social_image = 'og-store.jpg' | asset_url | prepend: 'https:'
      assign social_sized = true
      if request.page_type == 'product' and product.featured_image
        assign social_image = product.featured_image | image_url: width: 1200 | prepend: 'https:'
        assign social_sized = false
      endif
    -%}
    <meta property="og:site_name" content="{{ shop.name | escape }}">
    <meta property="og:title" content="{{ page_title | escape }}">
    {%- if page_description %}
      <meta property="og:description" content="{{ page_description | escape }}">
    {%- endif %}
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:type" content="{% if request.page_type == 'product' %}product{% else %}website{% endif %}">
    <meta property="og:image" content="{{ social_image }}">
    {%- if social_sized %}
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="630">
    {%- endif %}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ page_title | escape }}">
    {%- if page_description %}
      <meta name="twitter:description" content="{{ page_description | escape }}">
    {%- endif %}
    <meta name="twitter:image" content="{{ social_image }}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;800&family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap">

    {{ 'theme.css' | asset_url | stylesheet_tag }}

    {{ content_for_header }}
  </head>
  <body>
    <a class="skip-link" href="#MainContent">Skip to content</a>

    <canvas id="galaxy-field" class="galaxy" aria-hidden="true"></canvas>
    <div class="aurora aurora--1" aria-hidden="true"></div>
    <div class="aurora aurora--2" aria-hidden="true"></div>
    <div class="aurora aurora--3" aria-hidden="true"></div>

    {% section 'header' %}

    <main id="MainContent" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <script src="{{ 'galaxy.js' | asset_url }}" defer></script>
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
