{%- liquid
  assign eyebrow = section.settings.eyebrow
  assign prefix = section.settings.heading_prefix
  assign accent = section.settings.heading_accent
  assign subtext = section.settings.subtext
  assign cta_label = section.settings.cta_label
  assign cta_url = section.settings.cta_url
-%}

<section class="hero">
  <div class="wrap">
    {%- if eyebrow != blank -%}
      <span class="eyebrow hero__eyebrow">{{ eyebrow }}</span>
    {%- endif -%}

    <h1 class="hero__title">
      {%- if prefix != blank -%}{{ prefix }} {% endif -%}
      {%- if accent != blank -%}<span class="text-gradient">{{ accent }}</span>{%- endif -%}
    </h1>

    {%- if subtext != blank -%}
      <p class="hero__subtext">{{ subtext }}</p>
    {%- endif -%}

    {%- if cta_label != blank -%}
      <div class="hero__cta">
        <a class="btn btn-primary" href="{{ cta_url | default: routes.all_products_collection_url }}">{{ cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Official store"
    },
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "Heading prefix",
      "default": "Wear the"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent",
      "info": "Rendered with the pink to cyan gradient.",
      "default": "grid glow"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Race-day gear from Daniel Oliver. Built for the sim rig and the paddock alike."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
