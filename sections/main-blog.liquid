<section class="section">
  <div class="wrap">
    <div class="section-head">
      <h1 class="section-head__title">{{ blog.title }}</h1>
    </div>

    {%- if blog.articles.size > 0 -%}
      {%- paginate blog.articles by 12 -%}
        <div class="article-grid">
          {%- for article in blog.articles -%}
            <a class="article-card" href="{{ article.url }}">
              {%- if article.image -%}
                <div class="article-card__media">
                  <img
                    src="{{ article.image | image_url: width: 800 }}"
                    srcset="{{ article.image | image_url: width: 400 }} 400w, {{ article.image | image_url: width: 800 }} 800w"
                    sizes="(min-width: 900px) 33vw, 100vw"
                    width="{{ article.image.width }}"
                    height="{{ article.image.height }}"
                    alt="{{ article.image.alt | default: article.title | escape }}"
                    loading="lazy">
                </div>
              {%- endif -%}
              <div class="article-card__body">
                <span class="article-card__date">{{ article.published_at | date: '%b %d, %Y' }}</span>
                <h2 class="article-card__title">{{ article.title }}</h2>
                <p class="article-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
              </div>
            </a>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" aria-label="Pagination">
            {{ paginate | default_pagination }}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <div class="empty-state">
        <h2 class="empty-state__heading">No posts yet</h2>
        <p>Articles will show up here once they are published.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
