{%- liquid
  assign footer_menu = linklists['footer']
  assign motto = settings.footer_motto | default: 'DO · SIM → REAL'
  assign main_site = settings.main_site_url | default: 'https://danieloliverracing.com'
-%}

<footer class="site-footer">
  <div class="wrap site-footer__grid">
    <div>
      <p class="site-footer__motto text-gradient">{{ motto }}</p>
    </div>

    {%- if footer_menu.links.size > 0 -%}
      <nav class="footer-nav" aria-label="Footer">
        {%- for link in footer_menu.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      </nav>
    {%- endif -%}

    {%- if settings.social_instagram != blank or settings.social_youtube != blank or settings.social_tiktok != blank -%}
      <div class="social-links">
        {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" aria-label="Instagram" rel="noopener" target="_blank">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
            </svg>
          </a>
        {%- endif -%}
        {%- if settings.social_youtube != blank -%}
          <a href="{{ settings.social_youtube }}" aria-label="YouTube" rel="noopener" target="_blank">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="2" y="5" width="20" height="14" rx="4"></rect>
              <path d="M10 9l5 3-5 3z" fill="currentColor" stroke="none"></path>
            </svg>
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok != blank -%}
          <a href="{{ settings.social_tiktok }}" aria-label="TikTok" rel="noopener" target="_blank">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M14 4v9.5a3.5 3.5 0 1 1-3.5-3.5"></path>
              <path d="M14 4c0 2.5 2 4.5 4.5 4.5"></path>
            </svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <div class="wrap site-footer__meta">
    <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
    <div class="site-footer__meta-end">
      <a href="{{ main_site }}" rel="noopener" target="_blank">danieloliverracing.com</a>
      <a
        class="powered-by-shopify"
        href="https://www.shopify.com"
        rel="noopener"
        target="_blank"
        aria-label="Powered by Shopify">
        <svg class="powered-by-shopify__logo" viewBox="0 0 448 512" aria-hidden="true" focusable="false">
          <path fill="#95BF46" d="M388.32,104.1a4.66,4.66,0,0,0-4.4-3.9c-1.8-.1-36.9-.7-36.9-.7s-29.4-28.5-32.3-31.4-8.5-2-10.7-1.4c0,0-5.5,1.7-14.8,4.6-1.5-5-3.8-11.1-7-17.2C272,32.9,257.7,23,240.4,23a19.16,19.16,0,0,0-4.9.5c-.5-.6-1-1.1-1.6-1.7C227,14,218.5,10.6,208.3,10.9c-19.7.6-39.3,14.8-55.2,40.1-11.2,17.8-19.7,40.2-22.1,57.5-22.6,7-38.4,11.9-38.8,12-11.4,3.6-11.8,3.9-13.3,14.7C77.5,147.4,47.6,379,47.6,379L297.3,422.1l108.2-26.9S388.5,105.4,388.32,104.1ZM271.2,72.4c-7,2.2-14.9,4.6-23.5,7.3,0-12.2-1.6-29.5-7.3-44.4C258.9,39.1,268.4,60.4,271.2,72.4Zm-38.6,12c-15.7,4.9-32.9,10.2-50,15.5,4.8-18.5,14-37,25.2-49.1a53.76,53.76,0,0,1,17.9-13C232.9,49.7,232.9,72.6,232.6,84.4ZM208.6,26.8c4,0,7.4,1.2,10.4,3.6-9.8,4.6-20.4,14.3-28.4,28.7-6.3,11.4-11.2,25.2-13.2,38.4-14.2,4.4-28.1,8.7-40.9,12.7C143.3,73.4,173.9,27.8,208.6,26.8Z"/>
          <path fill="#5E8E3E" d="M383.92,100.2c-1.8-.1-36.9-.7-36.9-.7s-29.4-28.5-32.3-31.4a7.28,7.28,0,0,0-4.1-1.9V422.1l108.2-26.9S388.5,105.4,388.3,104.1A4.66,4.66,0,0,0,383.92,100.2Z"/>
          <path fill="#FFF" d="M240.3,155.6,227.7,202.5a72.55,72.55,0,0,0-30.5-5.5c-24.6,1-24.9,16.5-24.7,20.4,1.3,21.3,57.4,26,60.6,76,2.5,39.3-20.8,66.2-54.4,68.3-40.4,2.5-62.6-21.3-62.6-21.3l8.6-36.4s22.4,16.9,40.3,15.7c11.7-.7,15.9-10.3,15.5-17-1.7-27.8-47.4-26.2-50.3-71.9-2.5-38.5,22.8-77.5,78.5-81C229.3,150.1,240.3,155.6,240.3,155.6Z"/>
        </svg>
        <span>Powered by Shopify</span>
      </a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "paragraph",
      "content": "Social links, the motto and the main-site URL are set in Theme settings → Brand. Add a navigation menu with the handle 'footer' to show footer links."
    }
  ]
}
{% endschema %}
