{%- liquid
  assign product = product
  assign current = product.selected_or_first_available_variant
  assign featured = product.selected_or_first_available_variant.featured_media | default: product.featured_media
-%}

<section class="wrap product">
  <div class="product__media">
    <div class="product__feature">
      {%- if featured -%}
        <img
          src="{{ featured.preview_image | image_url: width: 1000 }}"
          srcset="
            {{ featured.preview_image | image_url: width: 500 }} 500w,
            {{ featured.preview_image | image_url: width: 1000 }} 1000w,
            {{ featured.preview_image | image_url: width: 1500 }} 1500w"
          sizes="(min-width: 900px) 50vw, 100vw"
          width="{{ featured.preview_image.width }}"
          height="{{ featured.preview_image.height }}"
          alt="{{ featured.preview_image.alt | default: product.title | escape }}"
          data-product-feature>
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}
    </div>

    {%- if product.media.size > 1 -%}
      <div class="product__thumbs">
        {%- for media in product.media -%}
          <button class="product__thumb" type="button" aria-label="View image {{ forloop.index }} of {{ product.title | escape }}">
            <img
              src="{{ media.preview_image | image_url: width: 160 }}"
              srcset="{{ media.preview_image | image_url: width: 160 }} 1x, {{ media.preview_image | image_url: width: 320 }} 2x"
              width="{{ media.preview_image.width }}"
              height="{{ media.preview_image.height }}"
              alt="{{ media.preview_image.alt | default: product.title | escape }}"
              loading="lazy">
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="product__info">
    {%- if product.vendor != blank -%}
      <p class="product__vendor">{{ product.vendor }}</p>
    {%- endif -%}

    <h1 class="product__title">{{ product.title }}</h1>

    <div class="product__price" data-product-price>
      {% render 'price', product: product, variant: current %}
    </div>

    {%- form 'product', product, class: 'product-form', data-product-form: '' -%}
      {%- if product.variants.size > 1 -%}
        <div class="product-form__row">
          <label class="field-label" for="ProductVariant-{{ section.id }}">Variant</label>
          <select
            id="ProductVariant-{{ section.id }}"
            class="control"
            name="id"
            data-variant-select>
            {%- for variant in product.variants -%}
              <option
                value="{{ variant.id }}"
                data-price="{{ variant.price | money }}"
                data-available="{{ variant.available }}"
                {% unless variant.available %}disabled{% endunless %}
                {% if variant == current %}selected{% endif %}>
                {{ variant.title }}{% unless variant.available %} — Sold out{% endunless %}
              </option>
            {%- endfor -%}
          </select>
        </div>
      {%- else -%}
        <input type="hidden" name="id" value="{{ current.id }}" data-variant-select>
      {%- endif -%}

      <div class="product-form__row">
        <label class="field-label" for="Quantity-{{ section.id }}">Quantity</label>
        <input
          id="Quantity-{{ section.id }}"
          class="control qty"
          type="number"
          name="quantity"
          value="1"
          min="1"
          inputmode="numeric">
      </div>

      <button
        type="submit"
        name="add"
        class="btn btn-primary btn-block"
        data-add-to-cart
        data-label-available="{{ 'products.product.add_to_cart' | t }}"
        data-label-soldout="{{ 'products.product.sold_out' | t }}"
        {% unless current.available %}disabled{% endunless %}>
        <span data-btn-label>
          {%- if current.available -%}{{ 'products.product.add_to_cart' | t }}{%- else -%}{{ 'products.product.sold_out' | t }}{%- endif -%}
        </span>
      </button>

      <div class="dynamic-checkout">
        {{ form | payment_button }}
      </div>
    {%- endform -%}

    {%- if product.description != blank -%}
      <div class="rte">
        {{ product.description }}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
