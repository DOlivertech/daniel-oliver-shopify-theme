{%- liquid
  assign main_site = settings.main_site_url | default: 'https://danieloliverracing.com'
-%}

<section class="password-page">
  <img class="password-page__chibi" src="{{ 'chibi-daniel.webp' | asset_url }}" alt="" width="150" height="150">

  <span class="eyebrow">Official store</span>

  <h1 class="password-page__heading">
    Coming <span class="text-gradient">soon</span>
  </h1>

  {%- if shop.password_message != blank -%}
    <p class="password-page__message">{{ shop.password_message }}</p>
  {%- endif -%}

  {%- form 'storefront_password' -%}
    {%- if form.errors -%}
      <p class="password-page__errors">{{ form.errors | default_errors }}</p>
    {%- endif -%}
    <div class="password-form">
      <label class="field-label" for="password" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0)">Password</label>
      <input
        class="control"
        type="password"
        name="password"
        id="password"
        placeholder="Password"
        autocomplete="current-password"
        aria-label="Store password">
      <button type="submit" class="btn btn-primary">Enter</button>
    </div>
  {%- endform -%}

  <div class="password-page__login">
    <a href="{{ main_site }}" rel="noopener" target="_blank">danieloliverracing.com</a>
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "settings": []
}
{% endschema %}
